# Telegram API credentials — get them at https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+79001234567

# Groq API key — get it at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Deepgram — enables transcription of incoming voice messages (speech-to-text).
# Leave empty to disable voice handling. Get a key at https://console.deepgram.com/
# NOTE: put the REAL key in .env (git-ignored), NOT here — .env.example is committed.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2      # Deepgram model to use
DEEPGRAM_LANGUAGE=ru       # Language of incoming voice notes

# Voice replies (text-to-speech) — when someone sends a voice note, reply with a
# synthesised voice note. Uses free edge-tts (no key). Deepgram TTS is NOT used:
# it has no Russian voice.
VOICE_REPLY_ENABLED=true          # false = always reply with text
TTS_VOICE=ru-RU-DmitryNeural      # edge-tts voice (e.g. ru-RU-SvetlanaNeural for female)

# Optional tuning (defaults shown)
CONTEXT_WINDOW=6          # How many last messages to send to the LLM
MAX_MESSAGES_PER_SESSION=6  # After this many replies, bot signs off
